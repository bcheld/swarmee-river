# Swarmee River - Environment Variables (Secrets Only)
#
# Copy to `.env` and fill in values as needed.
# Do NOT commit real secrets.
#
# Policy:
# - End-user supported environment variables are secrets only (API keys / credentials).
# - All non-secret configuration lives in `.swarmee/settings.json` and/or CLI/TUI controls.
#
# `.env` is loaded automatically by the CLI at startup for local development.

###############################################################################
# Supported Secrets (Read By Swarmee)
###############################################################################

# OpenAI
# OPENAI_API_KEY="sk-..."

# GitHub Copilot / GitHub token (any one is sufficient)
# SWARMEE_GITHUB_COPILOT_API_KEY="..."
# GITHUB_TOKEN="..."
# GH_TOKEN="..."

###############################################################################
# External Provider Credentials (SDK-Managed)
###############################################################################

# AWS SDK credentials are resolved by botocore/boto3. Swarmee does not read these
# directly, but Bedrock model calls use the AWS SDK credential chain.
#
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_SESSION_TOKEN="..."  # optional (for temporary credentials)

